{
  "name": "frostbite-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "qa:browser": "node scripts/qa-browser.mjs",
    "qa:deploy": "node scripts/qa-deploy.mjs",
    "backup:flow": "powershell -ExecutionPolicy Bypass -File scripts/backup-flow-state.ps1",
    "smoke:flow-write": "node scripts/smoke-live-flow-write.mjs",
    "reset:empty-start": "node scripts/reset-flow-empty-start.mjs",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-baseline.ps1 -CheckReadOnlyApi"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.0",
    "vite": "^8.0.16"
  }
}
